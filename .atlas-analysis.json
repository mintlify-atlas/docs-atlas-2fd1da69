  "keyFeatures": [
    "Landlock-based process sandboxing",
    "Filesystem access control (read, write, execute)",
    "Network access control (TCP bind/connect)",
    "YAML configuration with named profiles",
    "MCP (Model Context Protocol) integration",
    "Best-effort mode for kernel compatibility",
    "Zero daemon, no root required"
  ],
  "publicApiSurface": [
    "--fs / -f (filesystem rules)",
    "--net / -n (network rules)",
    "--config / -c (config file)",
    "--named-config / -C (named profile)",
    "--mode / -m (run|mcp)",
    "--abi (Landlock ABI version)",
    "--best-effort (graceful degradation)",
    "--ignore-if-missing (skip missing paths)",
    "--restrict-scoped (IPC restrictions)",
    "--unsafe-host-runtime (runtime access)"
  ]
}
